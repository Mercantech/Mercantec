FRONTEND_PUBLISH_PORT=4040

# Valgfrit — intern Docker-host-port (bruges ALDRIG i offentlige URLs)
WEB_PORT=4040

# Offentlig URL (OAuth redirect/logout — uden intern port)
PUBLIC_SITE_URL=https://mercantec.tech

# Mercantec Auth (OAuth 2.0 + PKCE)
PUBLIC_AUTH_BASE_URL=https://auth.mercantec.tech
PUBLIC_AUTH_CLIENT_ID=demo
PUBLIC_AUTH_ISSUER=https://auth.mercantec.tech
PUBLIC_AUTH_AUDIENCE=mercantec-apps

# --- Traefik / Dokploy (prod) — subdomæner under mercantec.tech ---
# Cloudflare DNS + tunnel skal pege på Dokploy; Traefik router Host() matcher disse værdier.
STUDENTS_API_DOMAIN=api-students.mercantec.tech
STUDENTS_MEDIA_DOMAIN=media-students.mercantec.tech

# Frontend build — browser kalder API på domænet ovenfor
PUBLIC_STUDENTS_API_URL=https://api-students.mercantec.tech

# Students stack (postgres + minio)
POSTGRES_USER=students
POSTGRES_PASSWORD=students
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
STORAGE_PUBLIC_URL=https://media-students.mercantec.tech/student-projects

# Lokal dev (docker-compose.local.yml)
# STUDENTS_API_PUBLISH_PORT=4041
# POSTGRES_PUBLISH_PORT=5433
# MINIO_API_PUBLISH_PORT=9000
