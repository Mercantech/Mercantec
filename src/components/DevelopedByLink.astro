---
import {
  DEFAULT_CREDITS,
  MAGS,
  type ProjectCredits,
} from "../data/developers";

interface Props {
  credits?: ProjectCredits;
  accentColor?: string;
  accentBg?: string;
  class?: string;
  compact?: boolean;
}

const {
  credits = DEFAULT_CREDITS,
  accentColor = "#0e38ab",
  accentBg = "rgba(14, 56, 171, 0.08)",
  class: className = "",
  compact = false,
} = Astro.props;

const isTeam = credits.developers.length > 1;
const mags = credits.developers.find((dev) => dev.name === MAGS.name);
const h5Team = credits.developers.filter((dev) => dev.name !== MAGS.name);
const teamNames = h5Team.map((dev) => dev.name).join(" · ");
const teamDisplayName = compact
  ? `H5 + ${mags?.name ?? MAGS.name}`
  : `${teamNames}${mags ? ` + ${mags.name}` : ""}`;
const teamSublabel = compact ? "Holdet" : (credits.moreLabel ?? "Se holdet");
const style = `--branded-accent: ${accentColor}; --branded-accent-bg: ${accentBg}; --branded-glow-secondary: color-mix(in srgb, ${accentColor} 6%, transparent);`;
---

{
  isTeam && credits.moreUrl ? (
    <a
      href={credits.moreUrl}
      target="_blank"
      rel="noopener noreferrer"
      class:list={["branded-link", "developed-by-team", compact && "branded-link--compact", className]}
      style={style}
    >
      <span class="branded-link-mark" aria-hidden="true">
        <svg
          class="developed-by-team-icon"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
          />
        </svg>
      </span>
      <span class="branded-link-copy">
        <span class:list={["branded-link-action", compact && "branded-link-action--hide-compact"]}>
          Udviklet af
        </span>
        <span class="branded-link-name">
          {teamDisplayName}
        </span>
        <span class="branded-link-action">{teamSublabel}</span>
      </span>
      <svg
        class="branded-link-arrow"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
        />
      </svg>
    </a>
  ) : (
    <div class:list={["branded-link", "developed-by", compact && "branded-link--compact", className]} style={style}>
      <span class="branded-link-mark developed-by-mark" aria-hidden="true">M</span>
      <span class="branded-link-copy">
        <span class:list={["branded-link-action", compact && "branded-link-action--hide-compact"]}>
          Udviklet af
        </span>
        <span class="branded-link-name">
          <span class="branded-link-accent">{MAGS.name}</span>
        </span>
        <span class="developed-by-links">
          {
            MAGS.website && (
              <a href={MAGS.website} target="_blank" rel="noopener noreferrer">
                mags.dk
              </a>
            )
          }
          {MAGS.website && MAGS.github && <span class="developed-by-sep" aria-hidden="true">·</span>}
          {
            MAGS.github && (
              <a href={MAGS.github} target="_blank" rel="noopener noreferrer">
                {compact ? "GH" : "GitHub"}
              </a>
            )
          }
        </span>
      </span>
    </div>
  )
}

<style is:global>
  @import "../styles/branded-link.css";

  .developed-by-team-icon {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--branded-accent);
  }

  .developed-by-mark {
    font-family: ui-monospace, Consolas, monospace;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--branded-accent);
    line-height: 1;
  }

  .developed-by-links {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .developed-by-links a {
    color: var(--branded-accent);
    text-decoration: none;
  }

  .developed-by-links a:hover {
    text-decoration: underline;
  }

  .developed-by-sep {
    color: #94a3b8;
  }

  .developed-by:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--branded-accent) 35%, transparent);
    box-shadow:
      0 4px 14px color-mix(in srgb, var(--branded-accent) 20%, transparent),
      0 8px 24px color-mix(in srgb, var(--branded-accent) 12%, transparent);
  }
</style>
