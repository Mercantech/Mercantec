---
import { ecosystemNodes } from "../data/projects";

const hub = ecosystemNodes.find((n) => n.role === "hub")!;
const clients = ecosystemNodes.filter((n) => n.role === "client");
const future = ecosystemNodes.filter((n) => n.role === "future");
---

<section id="oekosystem" class="bg-white px-6 py-20">
  <div class="mx-auto max-w-4xl">
    <div class="reveal mb-12 text-center">
      <h2 class="mb-4 font-heading text-3xl font-bold text-text sm:text-4xl">
        Mercantec-økosystemet
      </h2>
      <p class="mx-auto max-w-2xl text-text/70">
        Alle platforme deler én central login via Mercantec Auth.
        Brugere logger ind én gang og får adgang på tværs af apps.
      </p>
    </div>

    <div class="reveal relative mx-auto flex flex-col items-center" style="animation-delay: 0.1s">
      <!-- Hub -->
      <a
        href={hub.url}
        target="_blank"
        rel="noopener noreferrer"
        class="relative z-10 flex flex-col items-center rounded-2xl border-2 border-primary bg-primary/5 px-8 py-6 shadow-lg transition-all hover:-translate-y-1 hover:shadow-xl"
      >
        <div class="mb-2 flex h-12 w-12 items-center justify-center rounded-full bg-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <span class="font-heading text-lg font-bold text-primary">{hub.name}</span>
        <span class="text-xs text-muted">Identity Provider</span>
      </a>

      <!-- Connector lines -->
      <div class="my-4 h-8 w-px bg-gray-300" aria-hidden="true"></div>

      <!-- Client nodes -->
      <div class="grid w-full grid-cols-2 gap-4 sm:grid-cols-3">
        {
          clients.map((node) =>
            node.url ? (
              <a
                href={node.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex flex-col items-center rounded-xl border border-gray-200/80 bg-white px-4 py-5 text-center shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md"
              >
                <span class="font-heading text-sm font-semibold text-text">{node.name}</span>
                <span class="mt-1 text-xs text-muted">Klient-app</span>
              </a>
            ) : (
              <div class="flex flex-col items-center rounded-xl border border-gray-200/80 bg-white px-4 py-5 text-center opacity-60">
                <span class="font-heading text-sm font-semibold text-text">{node.name}</span>
                <span class="mt-1 text-xs text-muted">Klient-app</span>
              </div>
            ),
          )
        }
        {
          future.map((node) => (
            <div class="flex flex-col items-center rounded-xl border border-dashed border-gray-300 bg-section px-4 py-5 text-center">
              <span class="font-heading text-sm font-semibold text-muted">{node.name}</span>
              <span class="mt-1 text-xs text-muted/70">Under udvikling</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
