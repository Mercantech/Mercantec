---
interface Props {
  href?: string;
  class?: string;
}

const {
  href = "https://learn.mags.dk",
  class: className = "",
} = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["gf2-platform-link", className]}
>
  <span class="gf2-platform-mark" aria-hidden="true">&lt;/&gt;</span>
  <span class="gf2-platform-copy">
    <span class="gf2-platform-name">
      GF2<span class="gf2-platform-accent">Learn</span>
    </span>
    <span class="gf2-platform-action">Åbn platform</span>
  </span>
  <svg
    class="gf2-platform-arrow"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>

<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&display=swap"
/>

<style>
  .gf2-platform-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem 0.65rem 0.75rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(2, 132, 199, 0.22);
    background:
      radial-gradient(ellipse 80% 120% at 100% 0%, rgba(124, 58, 237, 0.06), transparent 55%),
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    color: #0f172a;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    text-decoration: none;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.06),
      0 4px 20px rgba(2, 132, 199, 0.1);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      border-color 0.15s ease;
  }

  .gf2-platform-link:hover {
    color: #0f172a;
    text-decoration: none;
    transform: translateY(-1px);
    border-color: rgba(2, 132, 199, 0.35);
    box-shadow:
      0 4px 14px rgba(2, 132, 199, 0.2),
      0 8px 24px rgba(2, 132, 199, 0.12);
  }

  .gf2-platform-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    background: rgba(2, 132, 199, 0.12);
    border: 1px solid rgba(2, 132, 199, 0.25);
    font-family: ui-monospace, Consolas, monospace;
    font-size: 0.7rem;
    font-weight: 600;
    color: #0284c7;
    flex-shrink: 0;
  }

  .gf2-platform-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.05rem;
    min-width: 0;
  }

  .gf2-platform-name {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .gf2-platform-accent {
    color: #0284c7;
  }

  .gf2-platform-action {
    font-size: 0.72rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: 0.01em;
  }

  .gf2-platform-arrow {
    width: 1rem;
    height: 1rem;
    margin-left: 0.15rem;
    color: #0284c7;
    flex-shrink: 0;
  }
</style>
