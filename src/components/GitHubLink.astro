---
interface Props {
  href: string;
  sublabel?: string;
  class?: string;
}

const {
  href,
  sublabel = "Se kildekode",
  class: className = "",
} = Astro.props;

const accentColor = "#24292f";
const accentBg = "rgba(36, 41, 47, 0.08)";
const glowSecondary = "rgba(36, 41, 47, 0.06)";
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["branded-link", className]}
  style={`--branded-accent: ${accentColor}; --branded-accent-bg: ${accentBg}; --branded-glow-secondary: ${glowSecondary};`}
>
  <span class="branded-link-mark">
    <img src="/tech/github.svg" alt="" class="branded-link-mark-logo" loading="lazy" />
  </span>
  <span class="branded-link-copy">
    <span class="branded-link-name">
      Git<span class="branded-link-accent">Hub</span>
    </span>
    <span class="branded-link-action">{sublabel}</span>
  </span>
  <svg
    class="branded-link-arrow"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
  </svg>
</a>

<style is:global>
  @import "../styles/branded-link.css";
</style>
