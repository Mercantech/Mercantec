---
---

<section id="hero" class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-primary px-6 pt-20">
  <!-- Mesh gradient background -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-dark to-[#061e5c]"></div>
    <div class="absolute -top-1/4 -right-1/4 h-[600px] w-[600px] rounded-full bg-primary-light/20 blur-3xl"></div>
    <div class="absolute -bottom-1/4 -left-1/4 h-[500px] w-[500px] rounded-full bg-[#1a56db]/15 blur-3xl"></div>
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E')"
    ></div>
  </div>

  <div class="relative z-10 flex max-w-3xl flex-col items-center text-center">
    <img
      src="/brand/logo.svg"
      alt="Mercantec"
      class="mb-10 h-12 w-auto animate-fade-in-up sm:h-14"
    />

    <h1
      class="mb-6 font-heading text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl animate-fade-in-up"
      style="animation-delay: 0.1s"
    >
      Platforme bygget af elever
    </h1>

    <p
      class="mb-10 max-w-xl text-lg leading-relaxed text-white/80 sm:text-xl animate-fade-in-up"
      style="animation-delay: 0.2s"
    >
      Velkommen til Mercantec.tech — den centrale indgang til vores digitale platforme,
      bygget på Mercantec af elever til elever.
    </p>

    <a
      href="#projekter"
      class="inline-flex items-center gap-2 rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-primary transition-all hover:bg-white/90 hover:shadow-lg animate-fade-in-up"
      style="animation-delay: 0.3s"
    >
      Se vores projekter
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>

  <!-- Diagonal cut -->
  <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-full" preserveAspectRatio="none">
      <path d="M0 80L1440 0V80H0Z" fill="#f2f2f2" />
    </svg>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-16 left-1/2 z-10 -translate-x-1/2 animate-bounce-subtle" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
