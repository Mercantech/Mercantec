---
import AuthBar from "./AuthBar.astro";

const { pathname } = Astro.url;
const isHome = pathname === "/";
---

<header
  class:list={[
    "fixed top-0 left-0 right-0 z-50 border-b transition-colors duration-300",
    isHome ? "border-white/10 bg-primary/80 backdrop-blur-md" : "border-gray-200/60 bg-white/90 backdrop-blur-md",
  ]}
  id="navbar"
  data-on-hero={isHome ? "true" : "false"}
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3" aria-label="Mercantec forside">
      <img src="/brand/logo.svg" alt="Mercantec" class:list={["h-8 w-auto logo-light", { hidden: !isHome }]} />
      <img src="/brand/logo-dark.svg" alt="Mercantec" class:list={["h-8 w-auto logo-dark", { hidden: isHome }]} />
    </a>

    <div class="flex items-center gap-4 sm:gap-6">
      <a
        href={isHome ? "#projekter" : "/#projekter"}
        class:list={[
          "nav-link hidden text-sm font-medium transition-colors sm:inline",
          isHome ? "text-white/90 hover:text-white" : "text-text hover:text-primary",
        ]}
      >
        Projekter
      </a>
      <a
        href="/students"
        class:list={[
          "nav-link hidden text-sm font-medium transition-colors sm:inline",
          isHome ? "text-white/90 hover:text-white" : "text-text hover:text-primary",
        ]}
      >
        Elever
      </a>
      <a
        href={isHome ? "#oekosystem" : "/#oekosystem"}
        class:list={[
          "nav-link hidden text-sm font-medium transition-colors sm:inline",
          isHome ? "text-white/90 hover:text-white" : "text-text hover:text-primary",
        ]}
      >
        Økosystem
      </a>
      <AuthBar />
    </div>
  </nav>
</header>

<script>
  const navbar = document.getElementById("navbar");
  const hero = document.getElementById("hero");
  const startsOnHero = navbar?.dataset.onHero === "true";

  if (navbar && hero && startsOnHero) {
    const logoLight = navbar.querySelector(".logo-light");
    const logoDark = navbar.querySelector(".logo-dark");
    const navLinks = navbar.querySelectorAll(".nav-link");
    const navCta = navbar.querySelector(".nav-cta");

    const observer = new IntersectionObserver(
      ([entry]) => {
        const onHero = entry.isIntersecting;

        navbar.classList.toggle("bg-primary/80", onHero);
        navbar.classList.toggle("border-white/10", onHero);
        navbar.classList.toggle("bg-white/90", !onHero);
        navbar.classList.toggle("border-gray-200/60", !onHero);

        logoLight?.classList.toggle("hidden", !onHero);
        logoDark?.classList.toggle("hidden", onHero);

        navLinks.forEach((link) => {
          link.classList.toggle("text-white/90", onHero);
          link.classList.toggle("hover:text-white", onHero);
          link.classList.toggle("text-text", !onHero);
          link.classList.toggle("hover:text-primary", !onHero);
        });

        // navCta removed (mercantec.dk button)

        document.querySelectorAll(".auth-btn").forEach((btn) => {
          btn.classList.toggle("bg-white", onHero);
          btn.classList.toggle("text-primary", onHero);
          btn.classList.toggle("hover:bg-white/90", onHero);
          btn.classList.toggle("bg-primary", !onHero);
          btn.classList.toggle("text-white", !onHero);
          btn.classList.toggle("hover:bg-primary-dark", !onHero);
        });

        document.querySelectorAll(".auth-user-btn").forEach((btn) => {
          btn.classList.toggle("border-white/30", onHero);
          btn.classList.toggle("text-white", onHero);
          btn.classList.toggle("hover:bg-white/10", onHero);
          btn.classList.toggle("border-gray-200", !onHero);
          btn.classList.toggle("text-text", !onHero);
          btn.classList.toggle("hover:bg-gray-50", !onHero);
        });
      },
      { threshold: 0.1 },
    );

    observer.observe(hero);
  } else if (navbar && !startsOnHero) {
    document.querySelectorAll(".auth-btn").forEach((btn) => {
      btn.classList.remove("bg-white", "text-primary", "hover:bg-white/90");
      btn.classList.add("bg-primary", "text-white", "hover:bg-primary-dark");
    });

    document.querySelectorAll(".auth-user-btn").forEach((btn) => {
      btn.classList.remove("border-white/30", "text-white", "hover:bg-white/10");
      btn.classList.add("border-gray-200", "text-text", "hover:bg-gray-50");
    });
  }
</script>
