---
import type { Project } from "../data/projects";
import TechStack from "./TechStack.astro";
import PlatformLink from "./PlatformLink.astro";
import GitHubLink from "./GitHubLink.astro";
import DevelopedByLink from "./DevelopedByLink.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusLabels = {
  live: "Live",
  beta: "Beta",
  "coming-soon": "Kommer snart",
};

const statusColors = {
  live: "bg-emerald-100 text-emerald-700",
  beta: "bg-amber-100 text-amber-700",
  "coming-soon": "bg-gray-100 text-gray-600",
};
---

<article
  class="project-card group reveal flex h-full min-h-0 flex-col rounded-2xl border border-gray-200/60 bg-white p-8 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
  style={`--accent: ${project.accentColor}; border-top: 3px solid ${project.accentColor}`}
  data-project-card
  data-project-id={project.id}
  data-tech={project.techStack.map((t) => t.name.toLowerCase()).join(",")}
>
  <div class="project-card-header mb-6 flex shrink-0 items-start justify-between gap-4">
    <div class="flex min-w-0 items-center gap-4">
      <div
        class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl"
        style={`background: ${project.accentBg}`}
      >
        <img
          src={project.logo}
          alt={`${project.name} logo`}
          class="h-8 w-8 object-contain"
          loading="lazy"
        />
      </div>
      <div class="min-w-0">
        <h3 class="font-heading text-xl font-bold text-text">{project.name}</h3>
        <p class="text-sm text-muted">{project.tagline}</p>
      </div>
    </div>
    <span
      class={`shrink-0 rounded-full px-3 py-1 text-xs font-semibold ${statusColors[project.status]}`}
    >
      {statusLabels[project.status]}
    </span>
  </div>

  <div class="project-card-body flex min-h-0 flex-1 flex-col">
    <p class="project-card-description mb-6 flex-1 leading-relaxed text-text/80">{project.description}</p>

    <ul class="project-card-features mb-6 shrink-0 space-y-2">
      {
        project.features.map((feature) => (
          <li class="flex items-start gap-2 text-sm text-text/70">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0"
              style={`color: ${project.accentColor}`}
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
            {feature}
          </li>
        ))
      }
    </ul>

    <div class="project-card-tech mb-8 shrink-0">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted">Tech stack</p>
      <TechStack items={project.techStack} accentColor={project.accentColor} />
    </div>
  </div>

  <div class="project-card-actions shrink-0">
    <PlatformLink project={project} compact />
    {project.github && <GitHubLink href={project.github} compact />}
    <DevelopedByLink
      credits={project.credits}
      accentColor={project.accentColor}
      accentBg={project.accentBg}
      compact
    />
  </div>
</article>

<style>
  .project-card-header {
    min-height: 5.5rem;
  }

  .project-card-description {
    min-height: 5.5rem;
  }

  .project-card-features {
    min-height: 7.25rem;
  }

  .project-card-tech {
    min-height: 6.5rem;
  }

  .project-card-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 0.5rem;
    min-height: 3.35rem;
  }

  .project-card-actions > :global(.branded-link--compact:not(.developed-by-team):not(.developed-by-duo)) {
    flex: 1 1 0;
    min-width: 0;
  }
</style>

