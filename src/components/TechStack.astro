---
import type { TechItem } from "../data/projects";

interface Props {
  items: TechItem[];
  accentColor: string;
}

const { items, accentColor } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    items.map((item) => (
      <span
        class="tech-chip inline-flex items-center gap-1.5 rounded-lg border border-gray-200/80 bg-white px-2.5 py-1.5 text-xs font-medium text-text/80 shadow-sm transition-colors hover:border-gray-300 hover:shadow"
        style={`--tech-accent: ${accentColor}`}
      >
        <img
          src={item.icon}
          alt=""
          class="tech-chip__icon h-4 w-4 shrink-0 object-contain"
          loading="lazy"
        />
        {item.name}
      </span>
    ))
  }
</div>

<style>
  .tech-chip:hover {
    color: var(--tech-accent);
  }
</style>
