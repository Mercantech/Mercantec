---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mercantec — platforme bygget af elever",
  description = "Central hub for Mercantec.tech — udforsk vores platforme, projekter og tech stack.",
} = Astro.props;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/brand/favicon-32x32.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline src="/site-origin.js"></script>
    <script is:inline>
      (function () {
        var loc = window.location;
        var host = loc.hostname;
        var isMercantec =
          host === "mercantec.tech" || (host.length > 14 && host.slice(-14) === ".mercantec.tech");
        if (isMercantec && loc.port === "4040") {
          var path = loc.pathname.replace(/\/+$/, "") || "/";
          loc.replace("https://" + host + path + loc.search + loc.hash);
        }
      })();
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { getSiteOrigin, redirectIfInternalPort } from "../lib/auth";

      if (redirectIfInternalPort()) {
        // Afventer redirect til offentlig HTTPS-URL
      } else {

      function fixInternalLinks() {
        const origin = getSiteOrigin();
        const onMercantec =
          location.hostname === "mercantec.tech" ||
          location.hostname.endsWith(".mercantec.tech");

        document.querySelectorAll("a[href]").forEach((el) => {
          const href = el.getAttribute("href");
          if (!href || href.startsWith("#") || href.startsWith("mailto:") || href.startsWith("tel:")) {
            return;
          }

          if (href.startsWith("/")) {
            if (onMercantec || origin !== window.location.origin) {
              el.setAttribute("href", `${origin}${href}`);
            }
            return;
          }

          try {
            const url = new URL(href, window.location.href);
            const mercantec =
              url.hostname === "mercantec.tech" || url.hostname.endsWith(".mercantec.tech");
            if (!mercantec) return;

            if (url.port === "4040" || url.protocol === "http:") {
              el.setAttribute("href", `${origin}${url.pathname}${url.search}${url.hash}`);
            }
          } catch {
            // ignore invalid URLs
          }
        });
      }

      fixInternalLinks();
      new MutationObserver(fixInternalLinks).observe(document.body, {
        childList: true,
        subtree: true,
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
      );

      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
