---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Moderation — Elevprojekter" description="Godkend eller afvis elevprojekter">
  <Navbar />
  <main class="bg-section min-h-screen pt-24 pb-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="reveal mb-8">
        <a href="/students" class="mb-4 inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
          ← Tilbage til elevprojekter
        </a>
        <h1 class="font-heading text-3xl font-bold text-text">Moderation</h1>
        <p class="mt-2 text-text/70">Godkend eller afvis elevprojekter der afventer gennemgang.</p>
      </div>

      <div id="admin-denied" class="hidden reveal rounded-2xl border border-red-200 bg-red-50 px-6 py-8 text-center text-red-800">
        Du har ikke adgang til moderation. Kræver rolle Teacher eller Admin.
      </div>

      <div id="admin-auth" class="hidden reveal rounded-2xl border border-amber-200 bg-amber-50 px-6 py-8 text-center">
        <p class="mb-4 text-amber-900">Log ind med lærer- eller admin-konto.</p>
        <button type="button" id="admin-login-btn" class="rounded-full bg-primary px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary-dark">Log ind</button>
      </div>

      <div id="admin-loading" class="reveal text-muted">Henter afventende projekter…</div>
      <div id="admin-error" class="hidden reveal rounded-2xl border border-red-200 bg-red-50 px-6 py-4 text-red-800"></div>
      <div id="admin-empty" class="hidden reveal rounded-2xl border border-gray-200/60 bg-white px-8 py-12 text-center shadow-sm">
        <p class="text-text/80">Ingen projekter afventer godkendelse.</p>
      </div>
      <div id="admin-list" class="space-y-6"></div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import {
    approveProject,
    fetchPendingProjects,
    rejectProject,
    type StudentProject,
  } from "../../lib/students-api";
  import { isLoggedIn, isAdminOrTeacher, requireLogin } from "../../lib/students-auth";
  import { renderMediaGallery } from "../../lib/student-project-ui";

  const deniedEl = document.getElementById("admin-denied");
  const authEl = document.getElementById("admin-auth");
  const loadingEl = document.getElementById("admin-loading");
  const errorEl = document.getElementById("admin-error");
  const emptyEl = document.getElementById("admin-empty");
  const listEl = document.getElementById("admin-list");

  function escapeHtml(value: string): string {
    return value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  }

  function renderProject(project: StudentProject): string {
    const links = [
      project.liveUrl
        ? `<a href="${escapeHtml(project.liveUrl)}" target="_blank" rel="noopener" class="text-sm font-semibold text-primary hover:underline">Live</a>`
        : "",
      project.githubUrl
        ? `<a href="${escapeHtml(project.githubUrl)}" target="_blank" rel="noopener" class="text-sm font-semibold text-primary hover:underline">GitHub</a>`
        : "",
    ]
      .filter(Boolean)
      .join(" · ");

    return `
      <article class="rounded-2xl border border-gray-200/60 bg-white p-6 shadow-sm" data-project-id="${project.id}">
        <div class="mb-4 flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-sm text-muted">af ${escapeHtml(project.authorName)}</p>
            <h2 class="font-heading text-xl font-bold text-text">${escapeHtml(project.title)}</h2>
            <p class="text-sm text-muted">${escapeHtml(project.tagline)}</p>
          </div>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Afventer</span>
        </div>
        <p class="mb-4 leading-relaxed text-text/80 whitespace-pre-wrap">${escapeHtml(project.description)}</p>
        ${links ? `<p class="mb-4">${links}</p>` : ""}
        <div class="mb-4">${renderMediaGallery(project.media)}</div>
        <div class="flex flex-wrap items-end gap-3 border-t border-gray-100 pt-4">
          <button type="button" class="approve-btn rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white hover:bg-emerald-700" data-id="${project.id}">Godkend</button>
          <div class="flex min-w-0 flex-1 flex-col gap-2 sm:flex-row sm:items-center">
            <input type="text" class="reject-reason min-w-0 flex-1 rounded-xl border border-gray-200 px-3 py-2 text-sm" placeholder="Afvisningsårsag (påkrævet)" data-id="${project.id}" />
            <button type="button" class="reject-btn shrink-0 rounded-full border border-red-200 px-5 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" data-id="${project.id}">Afvis</button>
          </div>
        </div>
      </article>`;
  }

  async function loadPending() {
    if (!isLoggedIn()) {
      loadingEl?.classList.add("hidden");
      authEl?.classList.remove("hidden");
      return;
    }

    if (!isAdminOrTeacher()) {
      loadingEl?.classList.add("hidden");
      deniedEl?.classList.remove("hidden");
      return;
    }

    authEl?.classList.add("hidden");
    deniedEl?.classList.add("hidden");
    loadingEl?.classList.remove("hidden");
    errorEl?.classList.add("hidden");
    emptyEl?.classList.add("hidden");
    listEl!.innerHTML = "";

    try {
      const projects = await fetchPendingProjects();
      loadingEl?.classList.add("hidden");

      if (!projects.length) {
        emptyEl?.classList.remove("hidden");
        return;
      }

      listEl!.innerHTML = projects.map(renderProject).join("");

      listEl?.querySelectorAll(".approve-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const id = (btn as HTMLButtonElement).dataset.id;
          if (!id) return;
          try {
            await approveProject(id);
            (btn as HTMLButtonElement).closest("article")?.remove();
            if (!listEl?.children.length) emptyEl?.classList.remove("hidden");
          } catch (err) {
            alert(err instanceof Error ? err.message : "Godkendelse fejlede.");
          }
        });
      });

      listEl?.querySelectorAll(".reject-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const id = (btn as HTMLButtonElement).dataset.id;
          if (!id) return;
          const input = listEl?.querySelector<HTMLInputElement>(
            `.reject-reason[data-id="${id}"]`,
          );
          const reason = input?.value.trim() ?? "";
          if (!reason) {
            alert("Angiv en afvisningsårsag.");
            return;
          }
          try {
            await rejectProject(id, reason);
            (btn as HTMLButtonElement).closest("article")?.remove();
            if (!listEl?.children.length) emptyEl?.classList.remove("hidden");
          } catch (err) {
            alert(err instanceof Error ? err.message : "Afvisning fejlede.");
          }
        });
      });
    } catch (err) {
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
      if (errorEl) {
        errorEl.textContent =
          err instanceof Error ? err.message : "Kunne ikke hente afventende projekter.";
      }
    }
  }

  document.getElementById("admin-login-btn")?.addEventListener("click", () => {
    requireLogin("/students/admin");
  });

  window.addEventListener("mercantec-auth-changed", loadPending);
  loadPending();
</script>
