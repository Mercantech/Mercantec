---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { publicPath } from "../../lib/site-url";
---

<Layout
  title="Elevprojekter — Mercantec"
  description="Se projekter bygget af Mercantec-elever — med billeder, video, GitHub og live-demo."
>
  <Navbar />
  <main class="bg-section min-h-screen pt-24 pb-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="reveal mb-12 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h1 class="mb-4 font-heading text-3xl font-bold text-text sm:text-4xl">
            Elevprojekter
          </h1>
          <p class="max-w-2xl text-text/70">
            Udforsk projekter bygget af elever — med beskrivelse, tech stack, billeder og demo-links.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href={publicPath("/students/mine")}
            class="rounded-full border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-text transition-colors hover:bg-gray-50"
          >
            Mine projekter
          </a>
          <a
            href={publicPath("/students/indsend")}
            class="rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-dark"
          >
            Indsend projekt
          </a>
        </div>
      </div>

      <div id="students-loading" class="reveal text-center text-muted">Henter projekter…</div>
      <div id="students-error" class="hidden reveal rounded-2xl border border-red-200 bg-red-50 px-6 py-4 text-red-800"></div>
      <div id="students-empty" class="hidden reveal rounded-2xl border border-gray-200/60 bg-white px-8 py-12 text-center shadow-sm">
        <p class="mb-4 text-text/80">Ingen godkendte elevprojekter endnu.</p>
        <a href={publicPath("/students/indsend")} class="font-semibold text-primary hover:underline">Vær den første til at indsende et projekt</a>
      </div>
      <div id="students-grid" class="grid items-stretch gap-8 lg:grid-cols-2"></div>
      <div id="students-pagination" class="mt-10 flex justify-center gap-2"></div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { fetchApprovedProjects } from "../../lib/students-api";
  import { renderStudentProjectCard } from "../../lib/student-project-ui";

  const loadingEl = document.getElementById("students-loading");
  const errorEl = document.getElementById("students-error");
  const emptyEl = document.getElementById("students-empty");
  const gridEl = document.getElementById("students-grid");
  const paginationEl = document.getElementById("students-pagination");

  let currentPage = 1;

  async function loadPage(page: number) {
    loadingEl?.classList.remove("hidden");
    errorEl?.classList.add("hidden");
    emptyEl?.classList.add("hidden");
    gridEl!.innerHTML = "";
    paginationEl!.innerHTML = "";

    try {
      const data = await fetchApprovedProjects(page, 12);
      currentPage = data.page;
      loadingEl?.classList.add("hidden");

      if (!data.items.length) {
        emptyEl?.classList.remove("hidden");
        return;
      }

      gridEl!.innerHTML = data.items
        .map((project) =>
          `<div class="reveal visible flex h-full">${renderStudentProjectCard(project)}</div>`,
        )
        .join("");

      const totalPages = Math.ceil(data.total / data.pageSize);
      if (totalPages > 1) {
        for (let p = 1; p <= totalPages; p++) {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.textContent = String(p);
          btn.className = `rounded-full px-4 py-2 text-sm font-semibold ${
            p === currentPage
              ? "bg-primary text-white"
              : "border border-gray-200 bg-white text-text hover:bg-gray-50"
          }`;
          btn.addEventListener("click", () => loadPage(p));
          paginationEl?.appendChild(btn);
        }
      }
    } catch (err) {
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
      if (errorEl) {
        const raw = err instanceof Error ? err.message : "";
        const isNetwork =
          raw === "Failed to fetch" ||
          /failed to fetch|networkerror|load failed/i.test(raw);
        errorEl.textContent = isNetwork
          ? "Kunne ikke kontakte elevprojekt-API'en. Genstart deploy med hele docker-compose (web + students-api + postgres + minio)."
          : raw || "Kunne ikke hente elevprojekter.";
      }
    }
  }

  loadPage(1);
</script>
