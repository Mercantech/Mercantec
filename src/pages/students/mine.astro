---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Mine projekter — Elevprojekter" description="Dine indsendte elevprojekter">
  <Navbar />
  <main class="bg-section min-h-screen pt-24 pb-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="reveal mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <a href="/students" class="mb-4 inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
            ← Tilbage til elevprojekter
          </a>
          <h1 class="font-heading text-3xl font-bold text-text">Mine projekter</h1>
          <p class="mt-2 text-text/70">Se status på dine indsendelser og rediger kladder.</p>
        </div>
        <a href="/students/indsend" class="rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-dark">
          Nyt projekt
        </a>
      </div>

      <div id="mine-auth" class="hidden reveal rounded-2xl border border-amber-200 bg-amber-50 px-6 py-8 text-center">
        <p class="mb-4 text-amber-900">Log ind for at se dine projekter.</p>
        <button type="button" id="mine-login-btn" class="rounded-full bg-primary px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary-dark">Log ind</button>
      </div>

      <div id="mine-loading" class="reveal text-muted">Henter dine projekter…</div>
      <div id="mine-error" class="hidden reveal rounded-2xl border border-red-200 bg-red-50 px-6 py-4 text-red-800"></div>
      <div id="mine-empty" class="hidden reveal rounded-2xl border border-gray-200/60 bg-white px-8 py-12 text-center shadow-sm">
        <p class="mb-4 text-text/80">Du har ingen projekter endnu.</p>
        <a href="/students/indsend" class="font-semibold text-primary hover:underline">Opret dit første projekt</a>
      </div>
      <div id="mine-grid" class="grid items-stretch gap-8 lg:grid-cols-2"></div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { fetchMyProjects } from "../../lib/students-api";
  import { isLoggedIn, requireLogin } from "../../lib/students-auth";
  import { renderStudentProjectCard } from "../../lib/student-project-ui";

  const authEl = document.getElementById("mine-auth");
  const loadingEl = document.getElementById("mine-loading");
  const errorEl = document.getElementById("mine-error");
  const emptyEl = document.getElementById("mine-empty");
  const gridEl = document.getElementById("mine-grid");

  function escapeHtml(value: string): string {
    return value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  }

  async function loadMine() {
    if (!isLoggedIn()) {
      loadingEl?.classList.add("hidden");
      authEl?.classList.remove("hidden");
      return;
    }

    authEl?.classList.add("hidden");
    loadingEl?.classList.remove("hidden");
    errorEl?.classList.add("hidden");
    emptyEl?.classList.add("hidden");
    gridEl!.innerHTML = "";

    try {
      const projects = await fetchMyProjects();
      loadingEl?.classList.add("hidden");

      if (!projects.length) {
        emptyEl?.classList.remove("hidden");
        return;
      }

      gridEl!.innerHTML = projects
        .map((project) => {
          const card = renderStudentProjectCard(project, {
            showStatus: true,
            linkToDetail: project.status === "approved",
          });
          const editUrl = `/students/indsend?id=${project.id}`;
          const rejection =
            project.status === "rejected" && project.rejectionReason
              ? `<p class="mt-3 rounded-lg bg-red-50 px-3 py-2 text-sm text-red-800">Afvisningsårsag: ${escapeHtml(project.rejectionReason)}</p>`
              : "";
          const actions =
            project.status !== "pending"
              ? `<div class="mt-4 flex gap-2"><a href="${editUrl}" class="rounded-full border border-gray-200 px-4 py-2 text-sm font-semibold hover:bg-gray-50">Rediger</a></div>`
              : `<p class="mt-4 text-sm text-muted">Afventer godkendelse — kan ikke redigeres.</p>`;

          return `<div class="flex h-full flex-col">${card}${rejection}${actions}</div>`;
        })
        .join("");
    } catch (err) {
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
      if (errorEl) {
        errorEl.textContent =
          err instanceof Error ? err.message : "Kunne ikke hente dine projekter.";
      }
    }
  }

  document.getElementById("mine-login-btn")?.addEventListener("click", () => {
    requireLogin("/students/mine");
  });

  window.addEventListener("mercantec-auth-changed", loadMine);
  loadMine();
</script>
